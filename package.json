{
  "name": "shadowaudit",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "jest --projects packages/bff packages/scanner packages/notifier",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "dev": "bash start-local.sh",
    "dev:docker": "docker-compose up",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx,json}'"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.2"
  }
}
